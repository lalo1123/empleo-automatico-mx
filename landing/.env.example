# Base URL pública de la API del backend (Node/Hono self-hosted en Dokploy).
# INLINED EN EL BUNDLE DEL CLIENTE: se lee en build time, pasarlo como
# "Build Arg" en Dokploy (no basta con env runtime).
# Prod:     https://api.empleo.skybrandmx.com/v1
# Dev:      http://localhost:8787/v1
NEXT_PUBLIC_API_URL=https://api.empleo.skybrandmx.com/v1

# Origen público del landing (se usa para OG tags, sitemap.xml, robots.txt,
# canonical URLs). También se inlinea en algunos lugares del bundle —
# pasarlo como "Build Arg" en Dokploy.
# Prod:     https://empleo.skybrandmx.com
# Dev:      http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://empleo.skybrandmx.com

# Dominio donde se guarda la cookie de sesión (JWT).
# Solo server-side (no se inlinea en el bundle), así que basta como
# runtime env en Dokploy. El punto inicial la hace válida para todos los
# subdominios skybrandmx.com (ej. si mañana agregamos otro producto).
# Prod:     .skybrandmx.com
# Dev:      localhost
AUTH_COOKIE_DOMAIN=.skybrandmx.com

# Cloudflare Turnstile site key. Get keys at:
#   https://dash.cloudflare.com -> Turnstile -> Create widget
# INLINED EN EL BUNDLE DEL CLIENTE: pasarlo como "Build Arg" en Dokploy.
# Leave blank in dev; the signup/login forms won't render the widget and the
# backend (when TURNSTILE_SECRET is also blank) skips verification.
NEXT_PUBLIC_TURNSTILE_SITEKEY=

# OAuth 2.0 Client ID for Google Sign-In. Same value as GOOGLE_CLIENT_ID
# en el backend.
# Get it at: https://console.cloud.google.com/apis/credentials
#   -> "Create credentials" -> "OAuth client ID" -> "Web application".
# Whitelist these "Authorized JavaScript origins":
#   - https://empleo.skybrandmx.com   (prod)
#   - http://localhost:3000           (dev)
# INLINED EN EL BUNDLE DEL CLIENTE: pasarlo como "Build Arg" en Dokploy.
# Leave blank to hide the "Sign in with Google" button (forms still work
# with email/password).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------
# Dev values (descomentar para desarrollo local):
# NEXT_PUBLIC_API_URL=http://localhost:8787/v1
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# AUTH_COOKIE_DOMAIN=localhost
# NEXT_PUBLIC_TURNSTILE_SITEKEY=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
