# Empleo Automatico MX - backend env vars.
# Copy this file to `.env` for local dev (never commit the real one).
# In production, set these in Dokploy's env var UI.

# ---- Runtime --------------------------------------------------------------
NODE_ENV=development
PORT=8787

# SQLite file location. In Docker this maps to a persistent volume.
DATABASE_PATH=./data/empleo.db

# ---- Auth -----------------------------------------------------------------
# 32+ byte hex. Generate with: openssl rand -hex 32
JWT_SECRET=

# ---- Google Gemini --------------------------------------------------------
# From https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Conekta --------------------------------------------------------------
# Dashboard -> Configuracion -> API keys (test for dev, live for prod).
CONEKTA_API_KEY=
# Dashboard -> Webhooks -> Clave privada (used to verify HMAC-SHA1 signatures).
CONEKTA_WEBHOOK_KEY=
# Plan ids from Dashboard -> Planes.
CONEKTA_PLAN_PRO_MONTHLY=
CONEKTA_PLAN_PRO_YEARLY=
CONEKTA_PLAN_PREMIUM_MONTHLY=
CONEKTA_PLAN_PREMIUM_YEARLY=

# ---- Landing integration --------------------------------------------------
FRONTEND_BACK_URL=https://empleo.skybrandmx.com/account?sub=success
# Public URL of the landing (used to build email-verification links).
FRONTEND_URL=https://empleo.skybrandmx.com

# Comma-separated allowed Origins for CORS.
CORS_ORIGINS=https://empleo.skybrandmx.com,https://skybrandmx.com,chrome-extension://*,http://localhost:3000,http://localhost:5173

# ---- Anti-abuse -----------------------------------------------------------
# Cloudflare Turnstile secret. Get keys at https://dash.cloudflare.com -> Turnstile.
# Leave blank to SKIP CAPTCHA verification (dev / local testing only).
TURNSTILE_SECRET=
# Comma-separated extra disposable domains to block on signup (extends the
# bundled list in src/lib/disposable-domains.ts). Example:
#   DISPOSABLE_DOMAINS_EXTRA=badprovider.com,otherburner.io
DISPOSABLE_DOMAINS_EXTRA=

# ---- Google Sign-In -------------------------------------------------------
# OAuth 2.0 Client ID for the "Web application" client created at:
#   https://console.cloud.google.com/apis/credentials
# Whitelist the landing origin (https://empleo.skybrandmx.com and
# http://localhost:3000 for dev) under "Authorized JavaScript origins".
# Leave blank to disable Google Sign-In (POST /v1/auth/google returns
# 503 GOOGLE_OAUTH_DISABLED).
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the landing.
GOOGLE_CLIENT_ID=
